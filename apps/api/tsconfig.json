{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@agile-ish/config-tsconfig/nestjs.json",
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"],
      "@common/*": ["./src/common/*"],
      "@config/*": ["./src/config/*"],
      "@infra/*": ["./src/infra/*"],
      "@modules/*": ["./src/modules/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "prisma/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
