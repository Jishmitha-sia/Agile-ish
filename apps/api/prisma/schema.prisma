// ─────────────────────────────────────────────────────────────────────────────
// Agile-ish — Prisma schema (Phase 1)
//
// Conventions:
//   • All IDs are CUIDs (collision-resistant, URL-safe, sortable by creation).
//   • Soft-delete via `deletedAt` on tenant-scoped models. A Prisma client
//     extension (see PrismaService) intercepts `delete` and rewrites it to a
//     `deletedAt = now()` update, and filters reads to exclude deleted rows
//     unless an explicit `includeDeleted` flag is passed.
//   • Every tenant-scoped model carries `workspaceId`. A second Prisma
//     extension auto-injects the current request's `workspaceId` into queries
//     for these models. Postgres RLS policies (applied via SQL migration)
//     enforce the same rule at the DB layer — defense in depth.
//   • Audit log is append-only and never soft-deleted.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto, citext, pg_trgm, vector]
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum RefreshTokenRevocationReason {
  LOGOUT
  ROTATED
  REUSED // family-wide kill on token reuse — security event
  PASSWORD_CHANGED
  ADMIN_REVOKED
  EXPIRED
}

/// Discriminator for the unified EmailToken table — both email-verification
/// and password-reset flows share the same single-use, time-limited token
/// shape (SHA-256(token), expiry, usedAt) so we keep them in one model with
/// a `kind` column instead of two near-identical tables.
enum EmailTokenKind {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum OAuthProvider {
  GOOGLE
  GITHUB
}

// ─────────────────────────────────────────────────────────────────────────────
// User
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique @db.Citext
  passwordHash    String? // nullable: OIDC-only users have no local password
  displayName     String    @db.VarChar(80)
  avatarUrl       String?   @db.VarChar(2048)
  emailVerifiedAt DateTime?
  timezone        String?   @db.VarChar(64)
  locale          String?   @db.VarChar(16)
  lastLoginAt     DateTime?

  // Pointer to the user's preferred workspace — set after first signup,
  // updated when they switch. Denormalized for fast "redirect to workspace"
  // after login. Canonical truth is still WorkspaceMember rows.
  defaultWorkspaceId String?
  defaultWorkspace   Workspace? @relation("UserDefaultWorkspace", fields: [defaultWorkspaceId], references: [id], onDelete: SetNull)

  // Reverse relations
  memberships     WorkspaceMember[]
  refreshTokens   RefreshToken[]
  emailTokens     EmailToken[]
  oauthAccounts   OAuthAccount[]
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  auditLogs       AuditLog[]        @relation("AuditActor")
  invitesSent     WorkspaceMember[] @relation("InvitedBy")
  projectsLed     Project[]         @relation("ProjectLead")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([defaultWorkspaceId])
  @@index([deletedAt])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// RefreshToken — rotation with family-wide kill on reuse detection.
//
// A "family" is the chain of refresh tokens descending from a single login.
// Each rotation creates a new RefreshToken row with `parentId` pointing to
// the previous; the previous gets `replacedById` + `revokedAt`. If a *revoked*
// token is ever presented (replay attack), we revoke the ENTIRE family —
// every descendant gets `revokedReason = REUSED`. The user is forced to
// re-authenticate. This is the OWASP-recommended rotation pattern.
//
// We store SHA-256(tokenValue) — the raw token only lives in the httpOnly
// cookie and the user's browser. A DB leak does not yield usable tokens.
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id            String                        @id @default(cuid())
  userId        String
  user          User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId      String // shared across the rotation chain
  tokenHash     String                        @unique @db.Char(64) // sha256 hex
  parentId      String?
  parent        RefreshToken?                 @relation("TokenChain", fields: [parentId], references: [id], onDelete: SetNull)
  children      RefreshToken[]                @relation("TokenChain")
  replacedById  String?                       @unique
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason RefreshTokenRevocationReason?

  // Forensics for audit trail
  userAgent  String? @db.VarChar(512)
  ipAddress  String? @db.VarChar(64)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// EmailToken — unified table for email-verification + password-reset.
//
// Each row is single-use (`usedAt` is set the first time the token is
// successfully consumed) and time-limited (`expiresAt`). The actual token
// value lives only in the link sent to the user's email; the DB stores
// SHA-256(token) so a DB leak doesn't yield usable tokens.
//
// `kind` discriminates the two flows. Default TTLs (enforced at the
// service layer, not the DB):
//   EMAIL_VERIFICATION  → 24h
//   PASSWORD_RESET      → 1h
// ─────────────────────────────────────────────────────────────────────────────

model EmailToken {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      EmailTokenKind
  tokenHash String         @unique @db.Char(64) // sha256 hex
  expiresAt DateTime
  usedAt    DateTime?

  // Forensics — captured at request time, not at consumption time.
  ipAddress String? @db.VarChar(64)
  userAgent String? @db.VarChar(512)

  createdAt DateTime @default(now())

  @@index([userId, kind])
  @@index([expiresAt])
  @@map("email_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// OAuthAccount — links a User to a provider identity (Google, GitHub, …).
//
// `(provider, providerUserId)` is unique — that's the provider's stable id
// for this account. We also store the access / refresh / expiry triple so
// background jobs can call the provider's API on the user's behalf later
// (e.g. for Phase 6 GitHub integration). Tokens are stored as plain text
// for now — in Phase 2+ we'll wrap them with `pgcrypto` if/when scope of
// access tokens grows beyond identity.
// ─────────────────────────────────────────────────────────────────────────────

model OAuthAccount {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       OAuthProvider
  providerUserId String        @db.VarChar(255)
  // Profile snapshot at link time — useful for showing "linked as @x on
  // GitHub" without an extra round-trip.
  providerEmail  String?       @db.VarChar(255)
  providerHandle String?       @db.VarChar(255)
  // Tokens — optional. Stored only if we'll use them later (most flows
  // need only identity confirmation, after which the token is discarded).
  accessToken    String?       @db.Text
  refreshToken   String?       @db.Text
  expiresAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

// ─────────────────────────────────────────────────────────────────────────────
// Workspace — tenant root.
// ─────────────────────────────────────────────────────────────────────────────

model Workspace {
  id          String  @id @default(cuid())
  slug        String  @unique @db.VarChar(32)
  name        String  @db.VarChar(80)
  description String? @db.VarChar(500)
  avatarUrl   String? @db.VarChar(2048)

  // Denormalized owner pointer — fast "is X the owner" check without joining
  // WorkspaceMember. Membership row is still the source of truth for RBAC.
  ownerId String
  owner   User   @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  // Reverse relations
  members      WorkspaceMember[]
  defaultedBy  User[]            @relation("UserDefaultWorkspace")
  auditLogs    AuditLog[]
  projects     Project[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([ownerId])
  @@index([deletedAt])
  @@map("workspaces")
}

// ─────────────────────────────────────────────────────────────────────────────
// WorkspaceMember — RBAC join table.
//
// Composite PK (userId, workspaceId) prevents duplicate memberships at the
// schema level. `role` is the authoritative source for permission checks.
// ─────────────────────────────────────────────────────────────────────────────

model WorkspaceMember {
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(MEMBER)

  invitedById String?
  invitedBy   User?   @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, workspaceId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// Project — the unit of work that owns issues and sprints (Phase 3+).
//
// One Workspace has many Projects. Slug is unique within a workspace (e.g.
// two workspaces can each own a "web" project) — see the composite unique
// on (workspaceId, slug). `identifierPrefix` (e.g. "ENG") seeds the issue
// numbering scheme — issues will be ENG-1, ENG-2, … — and is also unique
// per-workspace so an issue's prefix unambiguously names its project.
// `issueCounter` is incremented atomically when an issue is created in
// Phase 3+; it lives here so we don't need a separate sequence table.
//
// `visibility` and `leadUserId` are present in the schema but only loosely
// used in Phase 2: every project is PUBLIC to workspace members and the
// lead defaults to NULL (workspace OWNER acts as the implicit lead). They
// exist now so we don't pay a migration to add them in Phase 3.
//
// Soft-delete via `deletedAt` from day one (we just converted Workspace
// to the same pattern). `archivedAt` is a distinct concept — "done with
// this project, hide it from active lists" — and is reserved for Phase 3+.
// ─────────────────────────────────────────────────────────────────────────────

enum ProjectVisibility {
  PUBLIC
  PRIVATE
}

model Project {
  id               String  @id @default(cuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  slug             String  @db.VarChar(32)
  name             String  @db.VarChar(80)
  description      String? @db.VarChar(500)
  identifierPrefix String  @db.VarChar(8)
  issueCounter     Int     @default(0)
  visibility       ProjectVisibility @default(PUBLIC)

  leadUserId String?
  lead       User?   @relation("ProjectLead", fields: [leadUserId], references: [id], onDelete: SetNull)

  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@unique([workspaceId, slug])
  @@unique([workspaceId, identifierPrefix])
  @@index([workspaceId, deletedAt])
  @@index([leadUserId])
  @@map("projects")
}

// ─────────────────────────────────────────────────────────────────────────────
// AuditLog — append-only system + workspace-scoped event log.
//
// `workspaceId` is nullable for system-level events (e.g. user signup before
// any workspace exists). `actorId` is nullable for system-driven actions
// (e.g. scheduled cleanups, automated invites).
//
// `metadata` is jsonb — call sites stay typed via @agile-ish/contracts.
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id          String  @id @default(cuid())
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  actorId     String?
  actor       User?      @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action      String     @db.VarChar(64)
  targetType  String?    @db.VarChar(32)
  targetId    String?    @db.VarChar(64)
  metadata    Json       @default("{}")

  ipAddress String? @db.VarChar(64)
  userAgent String? @db.VarChar(512)
  requestId String? @db.VarChar(64)

  createdAt DateTime @default(now())

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@map("audit_logs")
}
