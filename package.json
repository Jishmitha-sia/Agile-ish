{
  "name": "agile-ish",
  "version": "0.1.0",
  "private": true,
  "description": "Agile-ish — open-source AI-native Scrum collaboration platform.",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "prepare": "husky",
    "db:generate": "pnpm --filter @agile-ish/api db:generate",
    "db:migrate": "pnpm --filter @agile-ish/api db:migrate",
    "db:migrate:deploy": "pnpm --filter @agile-ish/api db:migrate:deploy",
    "db:seed": "pnpm --filter @agile-ish/api db:seed",
    "db:studio": "pnpm --filter @agile-ish/api db:studio",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml --env-file .env up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml --env-file .env down",
    "docker:logs": "docker compose -f infra/docker/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "dotenv-cli": "^7.4.2",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "rimraf": "^6.0.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
