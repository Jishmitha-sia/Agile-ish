# ─────────────────────────────────────────────────────────────────────────────
# Agile-ish — environment variables
# Copy to `.env` for local dev. Never commit `.env`. Production secrets live in
# your secret manager (Vault / sealed-secrets / SSM). Every variable here is
# validated at API boot via Zod — a missing or malformed value aborts startup.
# ─────────────────────────────────────────────────────────────────────────────

# ───── Runtime ─────
NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0
LOG_LEVEL=debug                       # trace | debug | info | warn | error | fatal
LOG_PRETTY=true                       # pretty-print logs in dev; JSON in prod

# ───── Public URLs (used in emails, CORS, OAuth callbacks) ─────
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000

# ───── Postgres ─────
# Two roles, two URLs (production-grade separation):
#   • POSTGRES_USER (`agile`) is the cluster superuser, used to run migrations
#     via DIRECT_URL — superuser is required for `CREATE EXTENSION`.
#   • `app_user` is a non-superuser role created by docker-init that the API
#     connects as at runtime. Because it lacks BYPASSRLS, the row-level
#     security policies in the schema are actually enforced.
POSTGRES_USER=agile
POSTGRES_PASSWORD=agile_local_dev_password
POSTGRES_DB=agile_ish
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
APP_USER_PASSWORD=app_user_local_dev_password
DATABASE_URL=postgresql://app_user:app_user_local_dev_password@localhost:5432/agile_ish?schema=public&connection_limit=10&pool_timeout=20
DIRECT_URL=postgresql://agile:agile_local_dev_password@localhost:5432/agile_ish?schema=public

# ───── Redis ─────
REDIS_URL=redis://localhost:6379
REDIS_NAMESPACE=agile-ish

# ───── JWT (RS256 — asymmetric) ─────
# Generate with:  openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#                 openssl rsa -in private.pem -pubout -out public.pem
# Then base64 the files:  base64 -w 0 private.pem
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
JWT_ISSUER=agile-ish
JWT_AUDIENCE=agile-ish-web
JWT_ACCESS_TTL_SECONDS=900            # 15 minutes
JWT_REFRESH_TTL_SECONDS=2592000       # 30 days

# ───── Cookies (refresh token transport) ─────
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false                   # MUST be true in prod (HTTPS only)
COOKIE_SAMESITE=lax                   # lax | strict | none
REFRESH_COOKIE_NAME=agile_rt
NEXT_PUBLIC_REFRESH_COOKIE_NAME=agile_rt

# ───── Argon2id (tuned for ~250ms on a modern server CPU) ─────
ARGON2_MEMORY_KIB=19456               # 19 MiB
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# ───── Rate limiting (Redis-backed) ─────
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_TTL_SECONDS=900
AUTH_RATE_LIMIT_MAX=10

# ───── SMTP (transactional email) ─────
SMTP_HOST=localhost
SMTP_PORT=1025                        # MailHog in docker-compose
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="Agile-ish <no-reply@agile-ish.local>"

# ───── OpenTelemetry (optional in dev) ─────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=agile-ish-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# ───── AI (Phase 6 — provider-agnostic via OpenAI-compatible API) ─────
AI_PROVIDER=ollama                    # ollama | openai-compatible
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=ollama
AI_MODEL=llama3.1:8b
AI_EMBEDDING_MODEL=nomic-embed-text

# ───── Vector store (Phase 6) ─────
VECTOR_BACKEND=pgvector               # pgvector | qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ───── Web (Next.js) ─────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ───── OAuth (Phase 1.5 — leave blank to disable providers) ─────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
